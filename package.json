{
  "name": "devhawk-blog",
  "private": true,
  "type": "module",
  "scripts": {
    "build-data": "\"$npm_execpath\" scripts/build-data.mjs",
    "build": "\"$npm_execpath\" run build-data && eleventy",
    "serve": "\"$npm_execpath\" run build-data && eleventy --serve",
    "clean": "rm -rf _site _generated"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0"
  }
}
