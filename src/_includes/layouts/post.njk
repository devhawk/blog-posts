---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ post.title }}</h1>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dateDisplay }}</time>
    {% if post.author and post.author.username != "devhawk" %}
    <div class="post-meta">
      <span class="meta-label">Author:</span>
      <span>{{ post.author.name }}</span>
    </div>
    {% endif %}
    {% if post.categories and post.categories.length %}
    <div class="post-meta">
      <span class="meta-label">Categories:</span>
      {%- for cat in post.categories %}
      <a href="/blog/categories/{{ cat.slug }}/" class="badge badge-category">{{ cat.name }}</a>
      {%- endfor %}
    </div>
    {% endif %}
    {% if post.tags and post.tags.length %}
    <div class="post-meta">
      <span class="meta-label">Tags:</span>
      {%- for tag in post.tags %}
      <a href="/blog/tags/{{ tag.slug }}/" class="badge badge-tag">{{ tag.name }}</a>
      {%- endfor %}
    </div>
    {% endif %}
    {% if post.series %}
    <div class="post-meta">
      <span class="meta-label">Series:</span>
      <a href="/blog/series/{{ post.series.slug }}/" class="badge badge-series">{{ post.series.name }}</a>
    </div>
    {% endif %}
  </header>
  <div class="post-content">
    {{ post.content | markdownify | safe }}
  </div>
  {% if post.comments and post.comments.length %}
  <section class="comments">
    <h2>Comments ({{ post.comments.length }})</h2>
    {%- for comment in post.comments %}
    <div class="comment">
      <div class="comment-meta">
        {% if comment.authorUrl %}
        <a href="{{ comment.authorUrl }}" class="comment-author" rel="nofollow noopener" target="_blank">{{ comment.authorName }}</a>
        {% else %}
        <span class="comment-author">{{ comment.authorName }}</span>
        {% endif %}
        <time datetime="{{ comment.date | htmlDateString }}">{{ comment.date | dateDisplay }}</time>
      </div>
      <div class="comment-body">{{ comment.content | escapeHtml | nl2br | safe }}</div>
    </div>
    {%- endfor %}
  </section>
  {% endif %}
</article>
